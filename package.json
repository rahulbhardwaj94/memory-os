{
  "name": "memory-os",
  "version": "0.1.0",
  "description": "Your AI's memory, owned by you — a unified, user-owned memory vault exposed via MCP",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "start": "npm run start --workspace=apps/server",
    "start:dev": "npm run start:dev --workspace=apps/server",
    "mcp:start": "npm run mcp:start --workspace=apps/server",
    "migrate": "prisma migrate dev --schema=prisma/schema.prisma",
    "migrate:deploy": "prisma migrate deploy --schema=prisma/schema.prisma",
    "generate": "prisma generate --schema=prisma/schema.prisma",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "tsc --noEmit -p tsconfig.base.json",
    "lint": "eslint ."
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.9.0",
    "prisma": "^5.19.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  },
  "dependencies": {
    "@prisma/client": "^5.19.0",
    "zod": "^3.25.76"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
