# Database — matches docker-compose.yml defaults
DATABASE_URL="postgresql://memory_os:memory_os@localhost:5432/memory_os"

# Embedding provider — pick one: openai | ollama | voyage | cohere | gemini
EMBEDDING_PROVIDER=openai

# OpenAI (required when EMBEDDING_PROVIDER=openai) — 1536 dims, default schema
OPENAI_API_KEY=sk-...

# Ollama (free, local) — 768 dims
# Run: ollama pull nomic-embed-text && npm run migrate && npm run migrate:ollama
# EMBEDDING_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=nomic-embed-text
# OLLAMA_DIMENSIONS=768

# Voyage AI (200M tokens/month free) — 512 dims (voyage-3-lite)
# Run: npm run migrate && npm run migrate:voyage
# EMBEDDING_PROVIDER=voyage
# VOYAGE_API_KEY=pa-...
# VOYAGE_MODEL=voyage-3-lite
# VOYAGE_DIMENSIONS=512

# Cohere (1000 calls/month free) — 1024 dims
# Run: npm run migrate && npm run migrate:cohere
# EMBEDDING_PROVIDER=cohere
# COHERE_API_KEY=...
# COHERE_MODEL=embed-english-v3.0
# COHERE_DIMENSIONS=1024

# Gemini (free via Google AI Studio) — 768 dims
# Run: npm run migrate && npm run migrate:gemini
# EMBEDDING_PROVIDER=gemini
# GEMINI_API_KEY=AIza...

# Server
PORT=3000
NODE_ENV=development
SESSION_TTL_SECONDS=3600

# Identity — auto-creates this user in the DB on first MCP start (used without MCP_API_KEY)
DEFAULT_USER_EMAIL=default@memory-os.local
MCP_CLIENT_NAME=mcp

# MCP API key — optional. When set, the MCP server authenticates as the key owner
# instead of DEFAULT_USER_EMAIL. Generate in the Web UI → Settings → API Keys.
# MCP_API_KEY=mo_...

# Rate limiting (REST API only — MCP stdio is unaffected)
# 120 requests per 60 000 ms per IP by default
RATE_LIMIT_TTL_MS=60000
RATE_LIMIT_MAX=120

# CORS — comma-separated allowed origins (only used in production)
CORS_ORIGIN=http://localhost:3001

# Better Auth — required for the HTTP server and Web UI
# Generate secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BETTER_AUTH_SECRET=change-me-to-a-random-32-char-secret!!
BETTER_AUTH_URL=http://localhost:3000
