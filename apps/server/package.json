{
  "name": "@memory-os/server",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start": "node --env-file=../../.env dist/main",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "mcp:start": "node --env-file=../../.env dist/mcp/mcp-server",
    "mcp:dev": "ts-node -r tsconfig-paths/register src/mcp/mcp-server.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run test/"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@nestjs/common": "^10.4.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/platform-express": "^10.4.0",
    "@nestjs/schedule": "^4.1.0",
    "@prisma/client": "^5.19.0",
    "openai": "^4.57.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.0",
    "@nestjs/testing": "^10.4.0",
    "@types/node": "^20.16.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  }
}
