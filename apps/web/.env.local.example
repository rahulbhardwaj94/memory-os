# URL of the memory-os HTTP server (NestJS, runs on PORT from root .env, default 3000)
# Used by Next.js rewrites to proxy /api/* — you usually don't need to change this locally.
API_URL=http://localhost:3000

# Used by the Better Auth client to know where to send auth requests.
# Must match the NestJS server URL (BETTER_AUTH_URL in root .env).
NEXT_PUBLIC_API_BASE=http://localhost:3000
